# ============================================================
# ПДД AI — переменные окружения
# Скопируй этот файл в .env.local (для локального запуска)
# и заполни значениями из Supabase. В Vercel эти же переменные
# добавь в Settings → Environment Variables.
# ============================================================

# Из Supabase: Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://ТВОЙ-ПРОЕКТ.supabase.co

# Из Supabase: Project Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=твой-anon-ключ

# (понадобится позже, на этапе AI-репетитора — НЕ публичный, серверный)
# ANTHROPIC_API_KEY=sk-ant-...
